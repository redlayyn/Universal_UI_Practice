  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435, \u043F\u0443\u0442\u043D\u0438\u043A!
    \u0414\u0440\u0435\u0432\u043D\u0438\u0435 \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430
    \u0441\u0431\u044B\u043B\u0438\u0441\u044C, \u0438 \u0432 \u044E\u0436\u043D\u043E\u043C
    \u0441\u0435\u043A\u0442\u043E\u0440\u0435 \u0438\u0433\u0440\u043E\u0432\u043E\u0439
    \u0437\u043E\u043D\u044B \u043E\u0442\u043A\u0440\u044B\u043B\u0441\u044F \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0440\u0430\u0437\u043B\u043E\u043C. \u041C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0430\u0442\u0447\u0438\u043A\u0438 \u0444\u0438\u043A\u0441\u0438\u0440\u0443\u044E\u0442
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u0439 \u0432\u0441\u043F\u043B\u0435\u0441\u043A
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u0440\u0435\u0434\u043A\u0438\u0445
    \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u043E\u0432. \u0422\u0435\u0431\u0435
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0442\u043E\u0447\u043A\u0443, \u0441\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u043D\u0430\u0442\u0438\u0441\u043A \u0430\u043D\u043E\u043C\u0430\u043B\u0438\u0438
    \u0438 \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u0432\u0441\u0435 \u043E\u0441\u043A\u043E\u043B\u043A\u0438,
    \u043F\u043E\u043A\u0430 \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0430\u044F
    \u044D\u043D\u0435\u0440\u0433\u0438\u044F \u043D\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B\u0430
    \u044D\u0442\u043E\u0442 \u0440\u0435\u0433\u0438\u043E\u043D. \u041F\u043E\u0441\u043F\u0435\u0448\u0438,
    \u0432\u0440\u0435\u043C\u044F \u043D\u0430 \u0438\u0441\u0445\u043E\u0434\u0435"
  m_isRightToLeft: 0
